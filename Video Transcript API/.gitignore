# Local task outputs and downloaded media
data/tasks/*
!data/tasks/.gitkeep
data/**/*.wav
data/**/*.m4a
data/**/*.mp3
data/**/*.aac
data/**/*.flac
data/**/*.mp4
data/**/*.json
data/**/*.txt

# Downloaded ASR models are large and machine-local.
models/*
!models/.gitkeep

# FunASR runtime model cache mounted by docker-compose.asr.yml.
funasr-runtime-resources/

# Local binaries and release archives.
tools/bbdown/*.zip
tools/bbdown/BBDown

# Python and test caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# OS/editor noise
.DS_Store
*.swp
*.swo
