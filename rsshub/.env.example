RSSHUB_IMAGE=diygod/rsshub
RSSHUB_BIND=127.0.0.1
RSSHUB_PORT=1200

# 默认缓存 5 分钟。如果后续有多个阅读器或自动化服务频繁轮询，可以适当调大。
CACHE_EXPIRE=300

# 可选。订阅较多 GitHub 路由时建议配置，用于提高 GitHub API 访问稳定性。
GITHUB_ACCESS_TOKEN=

# 可选。需要代理访问部分外部站点时配置，例如：http://host.docker.internal:7890
PROXY_URI=

# 本机使用保持 * 即可。如果后续接前端页面，建议改成前端站点的 Origin。
ALLOW_ORIGIN=*

# 可选。B 站动态路由经常需要 Cookie。变量名里的 uid 可以用自己的 B 站 UID。
# 示例：BILIBILI_COOKIE_123456=SESSDATA=...; bili_jct=...; DedeUserID=...
BILIBILI_COOKIE_=

# 可选。豆瓣相关路由如果遇到登录或风控问题，可以配置登录后的 Cookie。
DOUBAN_COOKIE=
