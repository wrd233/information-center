RSSHUB_IMAGE=diygod/rsshub
RSSHUB_BIND=127.0.0.1
RSSHUB_PORT=1200

# 默认缓存 5 分钟。如果后续有多个阅读器或自动化服务频繁轮询，可以适当调大。
CACHE_EXPIRE=300

# 可选。订阅较多 GitHub 路由时建议配置，用于提高 GitHub API 访问稳定性。
GITHUB_ACCESS_TOKEN=

# 可选。需要代理访问部分外部站点时配置，例如：http://host.docker.internal:7890
PROXY_URI=

# 本机使用保持 * 即可。如果后续接前端页面，建议改成前端站点的 Origin。
ALLOW_ORIGIN=*

# Bilibili 相关配置
# BILIBILI_COOKIE_{uid} 主要用于用户动态、关注列表等需要登录态的路由。
# 示例：BILIBILI_COOKIE_123456=SESSDATA=...; bili_jct=...; DedeUserID=...
BILIBILI_COOKIE_676149925='buvid3=5BDDC559-DA36-DC5F-AA07-76F52CD5626748799infoc; b_nut=1762848348; _uuid=231034AA2-C613-71031-33E1-7AED15ADD9FA00928infoc; buvid_fp=3ccc106edf8ea98cffce05dc1e569c4b; buvid4=D919C6A8-208A-55C8-DB7B-C19FEC47B3C502922-025111809-oTboRBgKTrqhICHnKDYFSg%3D%3D; CURRENT_FNVAL=2000; home_feed_column=4; _tea_utm_cache_10000007=undefined; browser_resolution=1161-833; bili_ticket=eyJhbGciOiJIUzI1NiIsImtpZCI6InMwMyIsInR5cCI6IkpXVCJ9.eyJleHAiOjE3Nzc4NjkxMzYsImlhdCI6MTc3NzYwOTg3NiwicGx0IjotMX0.sAsJD5beVYNd3SJWHHz0VFJSvTytFqs4DqhVzgykIZo; bili_ticket_expires=1777869076; theme-tip-show=SHOWED; theme-avatar-tip-show=SHOWED; SESSDATA=27ecd0e3%2C1793161974%2C2f769%2A51CjAAlGEEdkBUHghYhgGRVjRL7JyulE-K8JXnLIYz9LFYh6T8R_uhrPe5yJgRT5ycBEoSVkZCQ2RQekZVd1lmUGxZVjdaeGtkYS1XVHZnSGxCUnotdFotdnppdy1MeWhZTy1KaVVhaW50WEp0WEhGMHdldk1DTmlqWVJQNjdKdE1PV3Ewb2ZJSW5nIIEC; bili_jct=b11947834e9c2b4e453f49f45e048462; DedeUserID=676149925; DedeUserID__ckMd5=54d4adc62934da9d; sid=owat2xcb; b_lsid=B30D9263_19DE1CFBA63'

# BILIBILI_DM_IMG_LIST 可能用于 UP 主投稿视频等系列路由。
# 这是部署环境变量，保留在 .env 中即可，不需要写入 OPML 或脚本。
BILIBILI_DM_IMG_LIST='{"ds":[],"wh":[2897,1224,81],"of":[43,86,43]}'

# 可选。豆瓣相关路由如果遇到登录或风控问题，可以配置登录后的 Cookie。
DOUBAN_COOKIE=
