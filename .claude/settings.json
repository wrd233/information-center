{
  "defaultMode": "default",
  "disableBypassPermissionsMode": "disable",
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*secret*)",
      "Read(./**/*token*)",
      "Read(./**/*credential*)",
      "Read(./**/*key*)",
      "Read(./content_inbox/data/**)",
      "Read(./content_inbox/outputs/runs/**)",
      "Edit(./content_inbox/data/**)",
      "Edit(./content_inbox/outputs/runs/**)",
      "Write(./content_inbox/data/**)",
      "Write(./content_inbox/outputs/runs/**)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git push:*)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Bash(cat **/.env*)",
      "Bash(grep * .env*)",
      "Bash(grep -R * .env*)",
      "Bash(printenv:*)",
      "Bash(env:*)",
      "Bash(curl *api_key*)",
      "Bash(curl *token*)",
      "Bash(curl *secret*)"
    ],
    "ask": [
      "Edit",
      "Write",
      "MultiEdit",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pytest:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(curl:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(find . -maxdepth 3:*)",
      "Bash(wc:*)"
    ]
  }
}
